<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0">

    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controller.LoginController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/loginAction</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>JoinController</servlet-name>
        <servlet-class>controller.JoinController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>JoinController</servlet-name>
        <url-pattern>/joinAction</url-pattern>
    </servlet-mapping>
    
    <servlet>
 	   <servlet-name>BbsController</servlet-name>
 	   <servlet-class>controller.BbsController</servlet-class>
	</servlet>
	<servlet-mapping>
  		 <servlet-name>BbsController</servlet-name>
  		 <url-pattern>/bbsList</url-pattern>
	</servlet-mapping> 
    

</web-app>